# API Keys
TCGAPI_KEY=your_tcgapi_dev_key_here
RAPIDAPI_KEY=your_rapidapi_key_here

# Thresholds
MIN_PROFIT_DOLLARS=3.00
MIN_ROI_PCT=20.0
MIN_TCG_PRICE=5.00
MIN_EBAY_COMPS=5

# Fees (tune if platforms change rates)
TCG_FEE_RATE=0.1025
TCG_PAYMENT_RATE=0.025
DEFAULT_SHIPPING_IN=4.00
DEFAULT_SHIPPING_OUT=4.50

# Cache TTL (hours)
TCG_CACHE_HOURS=24
EBAY_CACHE_HOURS=6

# Scanner schedule
# Default 8h = 3 scans/day. With 30 cards:
#   tcgapi.dev:  ~30 calls/day (24h cache, free limit = 100)  ✅
#   RapidAPI:    ~90 calls/day — raise to 12 if hitting limits
SCAN_INTERVAL_HOURS=8

# Docker data paths (set automatically by docker-compose, leave blank for local dev)
# DB_PATH=/app/data/arbitrage.db
# OUTPUT_DIR=/app/data/output
